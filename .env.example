# Firebase config — copy to .env.local and fill with your project's values.
# Get these from the Firebase console: Project settings > General > Your apps > SDK setup.
# Dummy values let the app boot locally (auth/cloud sync just won't work).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
